{
  "buildCommand": "npm run build && mkdir -p dist/api && cp api/claude.js dist/api/",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/claude.js": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
